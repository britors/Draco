{
  "name": "prisma4postgres",
  "productName": "Prisma4Postgres",
  "description": "PostgreSQL explorer and Prisma ORM integration",
  "version": "1.0.0",
  "author": "britors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/britors/Prisma4Postgres.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node esbuild.js && electron out/main/index.js",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.britors.prisma4postgres",
    "productName": "Prisma4Postgres",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@vscode/codicons": "^0.0.36",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "pg": "^8.11.0"
  }
}
